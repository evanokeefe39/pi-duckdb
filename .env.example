# pi-duckdb environment — copy to .env and fill in. .env is gitignored.

# MotherDuck (optional) — cloud DuckDB.
# Create a token at https://app.motherduck.com -> Settings -> Access Tokens.
# Consumed by the `duckdb` CLI for `md:` connections and by the bundled
# MotherDuck skills. Leave blank if you are using local DuckDB only.
MOTHERDUCK_TOKEN=

# Optional: default MotherDuck database to ATTACH (e.g. my_db). Blank = none.
MOTHERDUCK_DATABASE=

# Local database file path (init-duckdb-project / protect-db-file).
# Tip: an absolute path OUTSIDE the project dir survives an accidental project wipe.
DUCKDB_DATABASE=

# Scheduled backups (setup-backups). Pick a location OUTSIDE the project dir.
DUCKDB_BACKUP_DIR=
# Optional offsite target, e.g. s3://my-bucket/duckdb-backups
DUCKDB_BACKUP_S3_URI=
